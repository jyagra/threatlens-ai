import json
import re
import urllib.parse
import requests
import joblib
from dotenv import load_dotenv
from openai import OpenAI

load_dotenv()

OPENAI_KEY = os.getenv("OPENAI_API_KEY")
ABUSE_KEY = os.getenv("ABUSEIPDB_API_KEY")
VT_KEY = os.getenv("VIRUSTOTAL_API_KEY")

client = OpenAI(api_key=OPENAI_KEY)

SCAN_FILE = "scan_history.json"

# Load ML model
model = joblib.load("phishing_model.pkl")
vectorizer = joblib.load("vectorizer.pkl")

# -----------------------------
# ML phishing detection
# -----------------------------
def ml_check(text):

    vec = vectorizer.transform([text])
    prediction = model.predict(vec)[0]

    if prediction == 1:
        return "⚠️ ML Model: Likely phishing"
    else:
        return "✅ ML Model: Likely legitimate"


# -----------------------------
# URL extraction
# -----------------------------
def extract_urls(text):

    pattern = r"(https?://[^\s]+)"
    return re.findall(pattern, text)


# -----------------------------
# IP extraction
# -----------------------------
def extract_ips(text):

    pattern = r"\b\d{1,3}(?:\.\d{1,3}){3}\b"
    return re.findall(pattern, text)


# -----------------------------
# IP reputation
# -----------------------------
def check_ip(ip):

    if not ABUSE_KEY:
        return None

    url = "https://api.abuseipdb.com/api/v2/check"

    params = {
        "ipAddress": ip,
        "maxAgeInDays": 90
    }

    headers = {
        "Key": ABUSE_KEY,
        "Accept": "application/json"
    }

    r = requests.get(url, headers=headers, params=params)

    if r.status_code == 200:

        data = r.json()
        score = data["data"]["abuseConfidenceScore"]

        if score > 0:
            return f"{ip} flagged ({score} abuse score)"

    return None


# -----------------------------
# Domain reputation
# -----------------------------
def check_domain(domain):

    if not VT_KEY:
        return None

    url = f"https://www.virustotal.com/api/v3/domains/{domain}"

    headers = {"x-apikey": VT_KEY}

    r = requests.get(url, headers=headers)

    if r.status_code == 200:

        stats = r.json()["data"]["attributes"]["last_analysis_stats"]

        malicious = stats["malicious"]
        suspicious = stats["suspicious"]

        if malicious > 0 or suspicious > 0:
            return f"{domain} flagged by vendors"

    return None


# -----------------------------
# AI phishing analysis
# -----------------------------
def ai_analysis(subject, sender, body):

    prompt = f"""
You are a cybersecurity phishing analyst.

Analyze the following email and determine if it is a phishing attempt.

Subject: {subject}
Sender: {sender}
Body: {body}

Return:

1. Risk Level
2. Explanation
3. Suspicious Indicators
4. Recommended Action
"""

    response = client.chat.completions.create(
        model="gpt-4.1-mini",
        messages=[{"role":"user","content":prompt}]
    )

    return response.choices[0].message.content


# -----------------------------
# Load history
# -----------------------------
def load_scans():

    if not os.path.exists(SCAN_FILE):
        return []

    with open(SCAN_FILE,"r") as f:
        return json.load(f)


# -----------------------------
# Save scan
# -----------------------------
def save_scan(entry):

    scans = load_scans()
    scans.append(entry)

    with open(SCAN_FILE,"w") as f:
        json.dump(scans,f,indent=2)


# -----------------------------
# UI
# -----------------------------
st.title("ThreatLens AI")

st.write("Phishing Detection & Email Threat Analysis")

subject = st.text_input("Email Subject")
sender = st.text_input("Sender Address")
body = st.text_area("Email Body")

if st.button("Analyze Email"):

    with st.spinner("Analyzing threat..."):

        ml_result = ml_check(body)
        ai_result = ai_analysis(subject, sender, body)

        urls = extract_urls(body)
        ips = extract_ips(body)

        domain_flags = []
        ip_flags = []

        for url in urls:

            parsed = urllib.parse.urlparse(url)
            domain = parsed.netloc

            vt = check_domain(domain)

            if vt:
                domain_flags.append(vt)

        for ip in ips:

            abuse = check_ip(ip)

            if abuse:
                ip_flags.append(abuse)

        st.subheader("Machine Learning Detection")
        st.write(ml_result)

        st.subheader("AI Analysis")
        st.write(ai_result)

        if domain_flags:
            st.subheader("Domain Intelligence")
            for d in domain_flags:
                st.write(d)

        if ip_flags:
            st.subheader("IP Reputation")
            for i in ip_flags:
                st.write(i)

        save_scan({
            "subject": subject,
            "sender": sender
        })


st.subheader("Recent Scans")

history = load_scans()

for h in history[-10:]:
    st.write(f"Analyzed: {h.get('subject','email')}")
