import streamlit as st
import pandas as pd
import joblib
import json
import datetime

st.set_page_config(page_title="ThreatLens AI", layout="wide")

st.title("ThreatLens AI")
st.subheader("Phishing Detection & Email Security Scanner")

# -----------------------------
# Load ML model
# -----------------------------

model = joblib.load("phishing_model.pkl")
vectorizer = joblib.load("vectorizer.pkl")

# -----------------------------
# Scan history storage
# -----------------------------

HISTORY_FILE = "scan_history.json"

try:
    with open(HISTORY_FILE, "r") as f:
        scan_history = json.load(f)
except:
    scan_history = []

# -----------------------------
# Free scan tracking
# -----------------------------

FREE_SCANS = 3

if "scan_count" not in st.session_state:
    st.session_state.scan_count = 0


# -----------------------------
# Machine Learning Detection
# -----------------------------

def ml_detect(text):

    vec = vectorizer.transform([text])

    prediction = model.predict(vec)[0]

    if prediction == 1:
        return "⚠️ Likely Phishing"
    else:
        return "✅ Likely Safe"


# -----------------------------
# Weekly Report Generator
# -----------------------------

def generate_weekly_report(history):

    total = len(history)

    phishing = sum(
        1 for h in history if "phishing" in h["result"].lower()
    )

    report = f"""
ThreatLens Weekly Security Report

Generated: {datetime.date.today()}

Emails analyzed: {total}
High-risk phishing attempts: {phishing}

Generated by ThreatLens AI
"""

    return report


# -----------------------------
# Email Scanner UI
# -----------------------------

subject = st.text_input("Email Subject")

sender = st.text_input("Sender Address")

body = st.text_area("Email Body")


# -----------------------------
# Analyze Email Button
# -----------------------------

if st.button("Analyze Email"):

    if st.session_state.scan_count >= FREE_SCANS:

        st.warning("Free scans used. Please subscribe to continue.")

    else:

        combined = subject + " " + body

        result = ml_detect(combined)

        st.subheader("Detection Result")

        st.write(result)

        st.session_state.scan_count += 1

        record = {
            "date": str(datetime.datetime.now()),
            "sender": sender,
            "subject": subject,
            "result": result
        }

        scan_history.append(record)

        with open(HISTORY_FILE, "w") as f:
            json.dump(scan_history, f)


# -----------------------------
# Show scan history
# -----------------------------

st.subheader("Recent Scans")

if len(scan_history) == 0:
    st.write("No scans yet.")

else:

    for h in reversed(scan_history[-10:]):

        st.write(
            f"{h['date']} | {h['sender']} | {h['subject']} → {h['result']}"
        )


# -----------------------------
# Weekly Report Download
# -----------------------------

st.subheader("Security Reports")

if st.button("Generate Weekly Report"):

    report = generate_weekly_report(scan_history)

    st.download_button(
        lel="Download Report",
        data=report,
        file_name="threatlens_weekly_report.txt"
    )


# -----------------------------
# Pricing Section
# -----------------------------

st.divider()

st.subheader("ThreatLens Pricing")

st.write("First **3 scans are FREE**")

st.write("")

